# Ignore docs by default, but keep hand-authored ADRs and the atomic-mail
# docs (both linked from CLAUDE.md). Use /docs/* so git still descends and
# the negations below take effect.
/docs/*
!/docs/adr/
!/docs/atomic_mail.md
/stripe-landing
/Notion
/logs

# User persona files (auto-seeded, should not be committed)
SOUL.md
~/.weebot/profiles/*/SOUL.md

