# ============================================================
# weebot — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.  Empty values are ignored.
# ============================================================


# ── AI Provider API Keys (at least ONE required) ─────────────
# OpenRouter — unified API for 350+ models (recommended)
OPENROUTER_API_KEY=

# DeepSeek — cost-efficient coding & reasoning
DEEPSEEK_API_KEY=

# Kimi — Moonshot AI
KIMI_API_KEY=

# Anthropic — Claude (optional, covered by OpenRouter)
ANTHROPIC_API_KEY=

# OpenAI — GPT-4 (optional, covered by OpenRouter)
OPENAI_API_KEY=


# ── Folders (all optional — defaults shown) ─────────────────
# Where weebot reads/writes files
# WEEBOT_WORKSPACE=.    (default: current directory)

# Where logs are written
# WEEBOT_LOGS_DIR=./logs

# Session database path
# WEEBOT_SESSIONS_DB=./weebot_sessions.db

# Cross-session memory files (AGENT.md / USER.md)
# WEEBOT_MEMORY_DIR=~/.weebot/memory

# User profile JSON storage
# WEEBOT_PROFILES_DIR=./user_profiles


# ── Defaults ─────────────────────────────────────────────────
# Default model (must be available via a configured provider)
# WEEBOT_MODEL=qwen/qwen3.7-plus

# Max AI spend per day in USD
DAILY_AI_BUDGET=10.0


# ── Sandbox ─────────────────────────────────────────────────
BASH_TIMEOUT=30
PYTHON_TIMEOUT=30
SANDBOX_MAX_OUTPUT_BYTES=65536
SANDBOX_ALLOW_NETWORK=false


# ── Browser Automation ──────────────────────────────────────
BROWSER_HEADLESS=false
BROWSER_USE_VISION=true
BROWSER_TIMEOUT=30000
