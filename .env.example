# ============================================================
# weebot — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
#
# pydantic-settings reads from .env automatically if the file
# exists in the current working directory.
# ============================================================


# ------------------------------------------------------------
# AI Provider API Keys  (at least ONE is required)
# ------------------------------------------------------------

# OpenAI — GPT-4, GPT-3.5-turbo, etc.
OPENAI_API_KEY=

# Anthropic — Claude 3.5 Sonnet, Claude 3 Opus, etc.
ANTHROPIC_API_KEY=

# Moonshot AI — Kimi models
KIMI_API_KEY=

# DeepSeek — DeepSeek-Chat, DeepSeek-Coder
DEEPSEEK_API_KEY=


# ------------------------------------------------------------
# Notifications  (all optional)
# ------------------------------------------------------------

# Telegram — get a bot token from @BotFather, chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=


# ------------------------------------------------------------
# Budget
# ------------------------------------------------------------

# Maximum AI spend per day in USD (default: 10.0)
DAILY_AI_BUDGET=10.0


# ------------------------------------------------------------
# Code Execution / Sandbox
# ------------------------------------------------------------

# Timeout in seconds for bash (PowerShell) commands (default: 30)
BASH_TIMEOUT=30

# Timeout in seconds for python_execute calls (default: 30)
PYTHON_TIMEOUT=30

# Maximum output captured per execution in bytes (default: 65536 = 64 KB)
SANDBOX_MAX_OUTPUT_BYTES=65536

# Allow the sandbox to make outbound network requests (default: false)
SANDBOX_ALLOW_NETWORK=false
